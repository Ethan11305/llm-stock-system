# 應用程式基本設定
APP_NAME=LLM Stock Advisory System
API_PREFIX=/api

# 資料庫與資料模式設定
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/llm_stock
USE_POSTGRES_MARKET_DATA=true
FALLBACK_TO_SAMPLE_DATA=true

# FinMind 資料來源設定
FINMIND_BASE_URL=https://api.finmindtrade.com/api/v4
FINMIND_API_TOKEN=
FINMIND_SYNC_ON_QUERY=true
STOCK_INFO_REFRESH_HOURS=24

# 台股公開資料來源設定
TWSE_COMPANY_FINANCIAL_URL=https://www.twse.com.tw/rwd/zh/IIH/company/financial
TWSE_MONTHLY_REVENUE_URL=https://openapi.twse.com.tw/v1/opendata/t187ap05_L

# 新聞檢索管線設定
NEWS_PIPELINE_ENABLED=true
GOOGLE_NEWS_RSS_ENABLED=true
GOOGLE_NEWS_RSS_BASE_URL=https://news.google.com/rss/search

# 低信心回答補強策略設定
PRELIMINARY_LLM_ANSWERS_ENABLED=true
LOW_CONFIDENCE_WARMUP_ENABLED=true
LOW_CONFIDENCE_WARMUP_THRESHOLD=0.80
LOW_CONFIDENCE_WARMUP_COOLDOWN_HOURS=12

# 檢索與信心門檻設定
MAX_RETRIEVAL_DOCS=8
MIN_GREEN_CONFIDENCE=0.80
MIN_YELLOW_CONFIDENCE=0.55

# OpenAI 與模型設定
MODEL_NAME=gpt-4.1-mini
OPENAI_BASE_URL=
OPENAI_API_KEY=
